    {
      "parameters": {
        "jsCode": "const html = $input.first().json.data;\nconst sheetData = $('Loop Over Items').first().json;\n\nconst priceMatch = html.match(/class=\"price_color\">\\s*([^<]+)/);\n\nlet price = null;\nif (priceMatch) {\n  const raw = priceMatch[1].replace(/[^\\d.]/g, '').trim();\n  price = parseFloat(raw);\n}\n\nreturn [{\n  json: {\n    product_name: sheetData.product_name,\n    url: sheetData.url,\n    target_price: sheetData.target_price,\n    last_price: sheetData.last_price,\n    current_price: price\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        336,
        256
      ],
      "id": "44ef387d-43b7-4ffd-a3f1-efb1fb05fdaf",
      "name": "extract price"
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\nconst currentPrice = parseFloat(item.current_price);\nconst targetPrice = parseFloat(item.target_price);\nconst lastPrice = parseFloat(item.last_price);\n\nconst dropped = currentPrice <= targetPrice;\nconst savings = lastPrice - currentPrice;\nconst pctOff = ((savings / lastPrice) * 100).toFixed(1);\n\nreturn [{ \n  json: { \n    product_name: item.product_name,\n    url: item.url,\n    target_price: targetPrice,\n    current_price: currentPrice,\n    last_price: lastPrice,\n    price_dropped: dropped,\n    savings: savings,\n    pct_off: pctOff\n  } \n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        512,
        256
      ],
      "id": "00828098-d271-4de3-98ab-4fac1f90b1af",
      "name": "compare"
    },
    {
      "parameters": {
        "jsCode": "const gemini = $input.first().json;\nconst item = $('compare').first().json;\nconst analysis = gemini.content?.parts?.[0]?.text || 'No analysis available';\n\nconst html = `\n<html><body style=\"font-family:sans-serif;max-width:600px;margin:auto;color:#222\">\n  <h2 style=\"color:#e63946\">Price Drop Alert!</h2>\n  <h3>${item.product_name}</h3>\n  <p>\n    <s style=\"color:#888\">$${item.last_price}</s>\n    <strong style=\"color:#2a9d8f;font-size:1.4em\"> $${item.current_price}</strong>\n    <span style=\"color:#e63946\"> Save $${item.savings} (${item.pct_off}% off)</span>\n  </p>\n  <h4>AI Deal Analysis</h4>\n  <p style=\"background:#f8f9fa;padding:12px;border-radius:8px\">${analysis}</p>\n  <a href=\"${item.url}\" style=\"background:#2a9d8f;color:white;padding:12px 24px;border-radius:6px;text-decoration:none;display:inline-block;margin-top:12px\">\n    View Deal\n  </a>\n</body></html>`;\n\nreturn [{ \n  json: { \n    html, \n    subject: `Price Drop: ${item.product_name} is now $${item.current_price}!`,\n    product_name: item.product_name,\n    url: item.url,\n    current_price: item.current_price,\n    last_price: item.last_price\n  } \n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
