        "messages": {
          "values": [
            {
              "content": "=You are a smart shopping assistant. Analyze this price drop and give a buying recommendation.\n\nProduct: {{ $json.product_name }}\nOriginal price: ${{ $json.last_price }}\nCurrent price: ${{ $json.current_price }}\nSavings: ${{ $json.savings }}\nDiscount: {{ $json.pct_off }}% off\nProduct URL: {{ $json.url }}\n\nAnswer these 3 things in short bullet points:\n- Is this a good deal? (Yes/No and why)\n- Best time to buy? (Now or wait)\n- Any caution? (refurbished, limited stock, etc)\n\nKeep it under 5 sentences total."
            }
          ]
        },
